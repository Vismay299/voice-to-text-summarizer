# Shared hosted rebuild environment
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# API service
API_PORT=8080
POSTGRES_URL=postgresql://user:password@localhost:5432/voice_to_text
GCS_BUCKET_NAME=voice-to-text-audio
HOSTED_LOCAL_AUDIO_DIR=/tmp/voice-to-text-summarizer/audio-chunks
PUBSUB_TOPIC_ASR=voice-to-text-asr
PUBSUB_TOPIC_SUMMARY=voice-to-text-summary
PUBSUB_SUBSCRIPTION_ASR=voice-to-text-asr-sub
PUBSUB_SUBSCRIPTION_SUMMARY=voice-to-text-summary-sub

# Transcription worker
ASR_MODEL_ID=large-v3-turbo
ASR_POLL_INTERVAL_MS=60000

# Summary worker
SUMMARY_MODEL_ID=Qwen2.5-7B-Instruct
SUMMARY_POLL_INTERVAL_MS=60000
LLM_SERVER_URL=http://localhost:8001
