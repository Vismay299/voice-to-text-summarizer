# Local-first environment
# GCP_PROJECT_ID=
# GCP_REGION=

# API service
API_PORT=8080
POSTGRES_URL=postgresql://user:password@localhost:5432/voice_to_text
# GCS_BUCKET_NAME=
HOSTED_LOCAL_AUDIO_DIR=/tmp/voice-to-text-summarizer/audio-chunks
HOSTED_DEFAULT_USER_ID=demo-user
HOSTED_REQUIRE_USER_ID=false
HOSTED_INTERNAL_API_KEY=change-me-for-internal-routes
# PUBSUB_TOPIC_ASR=
# PUBSUB_TOPIC_SUMMARY=
# PUBSUB_SUBSCRIPTION_ASR=
# PUBSUB_SUBSCRIPTION_SUMMARY=

# Transcription worker
ASR_MODEL_ID=large-v3
ASR_POLL_INTERVAL_MS=5000
ASR_CLAIM_TIMEOUT_MS=60000
ASR_LANGUAGE=en
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_BEAM_SIZE=5
ASR_VAD_FILTER=false
ASR_RETRY_WITHOUT_VAD_ON_EMPTY=true
ASR_NORMALIZE_AUDIO=true
ASR_NORMALIZATION_FILTER=highpass=f=60,lowpass=f=7600,loudnorm=I=-16:TP=-1.5:LRA=11
ASR_CPU_THREADS=4
ASR_NUM_WORKERS=1
ASR_MODEL_CACHE_DIR=/tmp/voice-to-text-summarizer/models

# Summary worker
SUMMARY_MODEL_ID=Qwen2.5-7B-Instruct
SUMMARY_POLL_INTERVAL_MS=60000
SUMMARY_CLAIM_TIMEOUT_MS=120000
LLM_SERVER_URL=http://localhost:8001

# Web client
VITE_HOSTED_USER_ID=demo-user
